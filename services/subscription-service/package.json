{
  "name": "@nightfuel/subscription-service",
  "version": "0.1.0",
  "description": "NightFuel subscription management microservice – tier, status and feature limit tracking.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@nightfuel/config": "*",
    "@nightfuel/events": "*",
    "@nightfuel/types": "*",
    "@prisma/client": "^5.10.2",
    "fastify": "^4.26.1",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.3.2",
    "pino": "^9.1.0",
    "stripe": "^14.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
