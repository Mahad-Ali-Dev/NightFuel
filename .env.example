# ═══════════════════════════════════════════════════════════════════════════════
# NightFuel — Root Environment Variables Example
# Copy to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── JWT (shared across all Node/Fastify services) ────────────────────────────
# Generate a strong secret with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# One logical database per service (Supabase or self-hosted Postgres 16)
# Local Docker format: postgresql://postgres:postgrespassword@localhost:5432/<db>
# Supabase format:     postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_auth
DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_auth

SHIFT_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_shifts
SHIFT_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_shifts

PLAN_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_plans
PLAN_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_plans

MEAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_meals
MEAL_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_meals

NOTIF_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_notifications
NOTIF_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_notifications

USER_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_users
USER_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_users

PROGRESS_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_progress
PROGRESS_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_progress

EXERCISE_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_exercise
EXERCISE_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_exercise

SLEEP_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_sleep
SLEEP_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_sleep

SUB_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_subscriptions
SUB_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_subscriptions

COMMUNITY_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_community
COMMUNITY_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_community

CHAT_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_chat
CHAT_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_chat

STATE_DATABASE_URL=postgresql://postgres:password@localhost:5432/nightfuel_state
STATE_DIRECT_URL=postgresql://postgres:password@localhost:5432/nightfuel_state

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local Docker:  redis://localhost:6379
# Upstash:       rediss://:TOKEN@your-instance.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ─── Service Ports ────────────────────────────────────────────────────────────
AUTH_PORT=3001
SHIFT_PORT=3002
# Python services use PORT internally: circadian-engine=3003, ai-pipeline=3004
PLAN_PORT=3005
MEAL_PORT=3006
PROGRESS_PORT=3007
NOTIF_PORT=3008
USER_PORT=3009
SLEEP_PORT=3010
EXERCISE_PORT=3011
SUB_PORT=3012
COMMUNITY_PORT=3013
CHAT_PORT=3014

# ─── AI Services ─────────────────────────────────────────────────────────────
# Anthropic (Claude API) — required for ai-pipeline LLM layer
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# OpenAI (optional: embeddings / fallback)
OPENAI_API_KEY=sk-REPLACE_ME

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Use sk_test_* locally and sk_live_* in production
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs created in Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
STRIPE_PREMIUM_PRICE_ID=price_REPLACE_ME

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BExampleVapidPublicKeyReplace64CharBase64UrlSafe==
VAPID_PRIVATE_KEY=ExampleVapidPrivateKeyReplace43CharBase64UrlSafe=
VAPID_SUBJECT=mailto:admin@nightfuel.app

# Expo push notifications (optional — enhances delivery for mobile)
# Get from: https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# ─── Web Client (Next.js) ────────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are embedded in the browser bundle at build time
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BExampleVapidPublicKeyReplace64CharBase64UrlSafe==
